rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ========================================================================
    // MODE DÉVELOPPEMENT - Autoriser tout (à restreindre en production)
    // ========================================================================
    
    // Pour le développement, on autorise toutes les opérations
    // TODO: Restreindre ces règles en production
    match /{document=**} {
      allow read, write: if true;
    }
    
    // ========================================================================
    // FONCTIONS UTILITAIRES (pour production)
    // ========================================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isSuperAdmin() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin';
    }
    
    function isMerchant(userId) {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.merchantId == userId;
    }
    
    function isValidApiKey() {
      return request.headers['X-API-Key'] != null;
    }
    
    function hasMerchantAccess(merchantId) {
      return isSuperAdmin() || isMerchant(merchantId);
    }
    
    // ========================================================================
    // RÈGLES DE PRODUCTION (commentées pour le développement)
    // ========================================================================
    
    /*
    // TRANSFERS
    match /transfers/{transferId} {
      allow read: if isAuthenticated() && 
                     hasMerchantAccess(resource.data.merchantId);
      allow create: if isAuthenticated() && 
                       isValidApiKey() &&
                       request.resource.data.merchantId == 
                       get(/databases/$(database)/documents/users/$(request.auth.uid)).data.merchantId;
      allow update: if isAuthenticated() && 
                       hasMerchantAccess(resource.data.merchantId) &&
                       request.resource.data.keys().hasOnly([
                         'status', 'paidAt', 'completedAt', 'updatedAt',
                         'errorCode', 'errorMessage', 'metadata'
                       ]);
      allow delete: if isSuperAdmin();
    }
    
    // MERCHANTS
    match /merchants/{merchantId} {
      allow read: if isAuthenticated() && 
                     (resource.data.id == request.auth.uid || isSuperAdmin());
      allow create: if isAuthenticated() && 
                       request.resource.data.id == request.auth.uid;
      allow update: if isAuthenticated() && 
                       (resource.data.id == request.auth.uid || isSuperAdmin());
      allow delete: if isSuperAdmin();
    }
    
    // USERS
    match /users/{userId} {
      allow read: if isAuthenticated() && 
                     (userId == request.auth.uid || isSuperAdmin());
      allow create: if request.auth != null && 
                       userId == request.auth.uid;
      allow update: if isAuthenticated() && 
                       (userId == request.auth.uid || isSuperAdmin());
      allow delete: if isSuperAdmin();
    }
    
    // WEBHOOKS
    match /webhooks/{webhookId} {
      allow read: if isAuthenticated() && 
                     hasMerchantAccess(resource.data.merchantId);
      allow create: if isAuthenticated() && 
                       isValidApiKey() &&
                       request.resource.data.merchantId == 
                       get(/databases/$(database)/documents/users/$(request.auth.uid)).data.merchantId;
      allow update, delete: if isAuthenticated() && 
                               hasMerchantAccess(resource.data.merchantId);
    }
    
    // RÈGLES PAR DÉFAUT
    match /{document=**} {
      allow read, write: if false;
    }
    */
  }
}
