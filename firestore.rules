rules_version = '2';

/**
 * LIVEPAY - Firestore Security Rules
 * 
 * CORE PHILOSOPHY:
 * This ruleset implements a strict "Merchant-Ownership" model. Access to all data is 
 * partitioned by the Merchant's unique identifier (UID), which corresponds to the 
 * Firebase Authentication UID.
 * 
 * DATA STRUCTURE:
 * The data is organized hierarchically:
 * - /merchants/{merchantId}: Root profile for the merchant.
 * - /merchants/{merchantId}/paymentRequests/{requestId}: Transactions generated by the merchant.
 * - /merchants/{merchantId}/apiKeys/{keyId}: Credentials for external platform integrations.
 * 
 * KEY SECURITY DECISIONS:
 * 1. Ownership Enforcement: Every path is prefixed with {merchantId}. Rules strictly 
 *    compare this path variable against `request.auth.uid`.
 * 2. Relational Integrity: On creation, we enforce that the internal `merchantId` field 
 *    matches the path variable to ensure data consistency.
 * 3. Prototyping Flexibility: During this phase, we do not enforce strict schema 
 *    validation (field types or optionality) to allow for rapid iteration, focusing 
 *    purely on robust authorization.
 * 4. Structural Segregation: By nesting all sub-entities under the merchant, we 
 *    automatically inherit the security context of the parent, making rules more 
 *    performant and avoiding costly `get()` calls.
 */

service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    /** @description Checks if the user is authenticated. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user matches the provided ID. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if the user is the owner and the document already exists. Used for updates and deletes. */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for the Merchant root collection.
     * @path /merchants/{merchantId}
     * @allow (get) Authenticated user 'abc' requests /merchants/abc.
     * @deny (list) Authenticated user 'abc' tries to list all /merchants.
     * @principle Self-creation and strict ownership of the profile document.
     */
    match /merchants/{merchantId} {
      allow get: if isOwner(merchantId);
      allow list: if false; // Users cannot discover other merchants.
      
      // On create, ensure the user creates their own profile and sets the ID correctly.
      allow create: if isOwner(merchantId) && request.resource.data.id == merchantId;
      
      // On update, ensure the ID field remains immutable for relational integrity.
      allow update: if isExistingOwner(merchantId) && request.resource.data.id == resource.data.id;
      
      allow delete: if isExistingOwner(merchantId);

      /**
       * @description Rules for payment requests generated by a merchant.
       * @path /merchants/{merchantId}/paymentRequests/{paymentRequestId}
       * @allow (create) Merchant 'abc' creates a request under /merchants/abc/paymentRequests/req123.
       * @deny (update) Merchant 'xyz' tries to update a request under /merchants/abc/paymentRequests/req123.
       * @principle Path-based authorization for transaction data.
       */
      match /paymentRequests/{paymentRequestId} {
        allow get, list: if isOwner(merchantId);
        
        // On create, validate the relationship field.
        allow create: if isOwner(merchantId) && request.resource.data.merchantId == merchantId;
        
        // On update, prevent the merchantId from being changed to another user.
        allow update: if isExistingOwner(merchantId) && request.resource.data.merchantId == resource.data.merchantId;
        
        allow delete: if isExistingOwner(merchantId);
      }

      /**
       * @description Rules for API keys used for external integrations.
       * @path /merchants/{merchantId}/apiKeys/{apiKeyId}
       * @allow (get) Merchant 'abc' retrieves their integration key 'key_789'.
       * @deny (create) Merchant 'abc' tries to create a key under /merchants/def/apiKeys/key_789.
       * @principle Protects sensitive integration credentials using owner-only access.
       */
      match /apiKeys/{apiKeyId} {
        allow get, list: if isOwner(merchantId);
        
        // On create, validate the relationship field.
        allow create: if isOwner(merchantId) && request.resource.data.merchantId == merchantId;
        
        // On update, prevent the merchantId from being changed.
        allow update: if isExistingOwner(merchantId) && request.resource.data.merchantId == resource.data.merchantId;
        
        allow delete: if isExistingOwner(merchantId);
      }
    }
  }
}